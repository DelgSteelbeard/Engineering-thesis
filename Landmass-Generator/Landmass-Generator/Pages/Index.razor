@page "/"
@using Landmass_Generator.Voronoi_Diagram

<h3>Voronoi Diagram Generator</h3>

<VoronoiDiagram Edges="GeneratedEdges" />

<button class="btn btn-primary" @onclick="GenerateDiagram">Generate Voronoi Diagram</button>

@code {
    private List<Edge> GeneratedEdges = new List<Edge>();

    private void GenerateDiagram()
    {
        var centroids = new List<Centroid>
        {
            new Centroid(200, 200),
            new Centroid(400, 200),
            new Centroid(300, 400),
            new Centroid(100, 300)
        };

        GeneratedEdges = Algorithms.GenerateVoronoiEdges(800, 800, centroids);
    }
}
